# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id_here

# OpenAI API
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Gmail 送信設定
# ※ GMAIL_APP_PASSWORD は「アプリパスワード」を使用してください
#   取得方法: Googleアカウント → セキュリティ → 2段階認証ON → アプリパスワード
GMAIL_USER=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx
GMAIL_TO=recipient@example.com
# 複数送信先はカンマ区切り: a@example.com,b@example.com

# GitHub Pages のベースURL（リポジトリを public にして Pages を有効化した後に設定）
# 例: https://yourname.github.io/instagram-content-analyzer
GITHUB_PAGES_BASE=https://yourname.github.io/instagram-content-analyzer

# アプリ設定
CACHE_HOURS=6
MAX_POSTS_TO_ANALYZE=50
REPORT_LANGUAGE=ja
